# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://doc_user:changeme@localhost:5432/doc_os

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-256-bit-secret
JWT_EXPIRES_IN=8h

# ─── AI / Model Providers ─────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_DEFAULT_MODEL=claude-opus-4-5
OPENAI_API_KEY=sk-proj-...

# ─── Storage (S3 / MinIO compatible) ─────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=doc-os-documents
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...

# ─── Service Ports ────────────────────────────────────────────────────────────
API_PORT=4000
ORCHESTRATOR_PORT=4001
WORKER_PORT=4002
PUBLIC_WEB_PORT=3000
ADMIN_WEB_PORT=3001

# ─── Service URLs ─────────────────────────────────────────────────────────────
API_URL=http://localhost:4000
ORCHESTRATOR_URL=http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=doc-os-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# ─── Email (SMTP placeholder) ─────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@doc.unykorn.org
SMTP_PASS=...

# ─── Intake ───────────────────────────────────────────────────────────────────
INTAKE_WEBHOOK_SECRET=replace-with-secret
