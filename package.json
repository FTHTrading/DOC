{
  "name": "doc-os",
  "private": true,
  "description": "DOC OS — Broker-Dealer Distribution, Compliance, and Orchestration Platform",
  "version": "1.0.0",
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "pnpm --filter @doc/db generate",
    "db:migrate": "pnpm --filter @doc/db migrate",
    "db:push": "pnpm --filter @doc/db push",
    "db:seed": "pnpm --filter @doc/db seed",
    "db:studio": "pnpm --filter @doc/db studio",
    "validate:local": "node test-local.js",
    "genesis:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-genesis-build.ps1",
    "genesis:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test-issuance.ps1",
    "boot:all": "powershell -ExecutionPolicy Bypass -File ./scripts/boot-all.ps1",
    "health:dashboard": "powershell -ExecutionPolicy Bypass -File ./scripts/health-dashboard.ps1",
    "cf:build:web": "pnpm --filter @doc/public-web build:cf",
    "cf:build:admin": "pnpm --filter @doc/admin-web build:cf",
    "cf:build": "pnpm cf:build:web && pnpm cf:build:admin",
    "cf:deploy": "powershell -ExecutionPolicy Bypass -File ./cloudflare/deploy.ps1",
    "cf:deploy:skip-build": "powershell -ExecutionPolicy Bypass -File ./cloudflare/deploy.ps1 -SkipBuild"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.14.0",
    "turbo": "^2.0.6",
    "typescript": "^5.5.2"
  }
}
